# Server
PORT=5000

# Client origin for CORS (no trailing slash)
CLIENT_URL=http://localhost:3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/fypwms

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m

# File uploads (optional — defaults to local ./uploads directory)
# UPLOAD_DIR=/var/data/uploads

# SMS — smsonlinegh.com
# Get your API key from your smsonlinegh.com account dashboard
SMS_API_KEY=your_smsonlinegh_api_key_here
# Sender name must be registered in your smsonlinegh.com account under SMS Messaging
SMS_SENDER=your_sender_name_here
